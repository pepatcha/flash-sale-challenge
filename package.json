{
  "name": "flash-sales",
  "version": "1.0.0",
  "description": "High-Concurrency Flash Sale System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "tsx tests/reset-and-seed.ts",
    "test:load": "k6 run -e LOAD_VUS=$(grep LOAD_VUS .env | cut -d= -f2) -e LOAD_ITERATIONS=$(grep LOAD_ITERATIONS .env | cut -d= -f2) -e INITIAL_STOCK=$(grep INITIAL_STOCK .env | cut -d= -f2) tests/load-test.js",
    "test:load:reset": "npm run db:reset && npm run test:load"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
